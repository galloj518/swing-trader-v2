{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swingtrader-v2/schemas/run_manifest.schema.json",
  "title": "SwingTraderRunManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "run_id",
    "generated_at",
    "as_of_date",
    "environment",
    "config_fingerprint",
    "runtime_mode",
    "inputs",
    "artifact_outputs"
  ],
  "properties": {
    "artifact_type": {
      "const": "run_manifest"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[a-z0-9_]+_[0-9]{8}_[0-9a-f]{16}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "as_of_date": {
      "type": "string",
      "format": "date"
    },
    "environment": {
      "type": "string",
      "enum": [
        "local",
        "github_actions"
      ]
    },
    "config_fingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "runtime_mode": {
      "type": "string",
      "enum": [
        "eod"
      ]
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "market_data_provider",
        "universe_name"
      ],
      "properties": {
        "market_data_provider": {
          "type": "string",
          "enum": [
            "yfinance",
            "schwab"
          ]
        },
        "universe_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact_outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_type",
          "artifact_id",
          "schema_version"
        ],
        "properties": {
          "artifact_type": {
            "type": "string",
            "enum": [
              "candidate_list",
              "packet",
              "ranking",
              "dashboard_payload",
              "decision_event",
              "outcome_record"
            ]
          },
          "artifact_id": {
            "type": "string",
            "minLength": 1
          },
          "schema_version": {
            "type": "string",
            "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
          }
        }
      }
    }
  }
}
