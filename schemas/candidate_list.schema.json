{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://swingtrader-v2/schemas/candidate_list.schema.json",
  "title": "SwingTraderCandidateList",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "schema_version",
    "run_id",
    "generated_at",
    "as_of_date",
    "environment",
    "config_fingerprint",
    "setup_family",
    "candidates"
  ],
  "properties": {
    "artifact_type": {
      "const": "candidate_list"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[a-z0-9_]+_[0-9]{8}_[0-9a-f]{16}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "as_of_date": {
      "type": "string",
      "format": "date"
    },
    "environment": {
      "type": "string",
      "enum": [
        "local",
        "github_actions"
      ]
    },
    "config_fingerprint": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "setup_family": {
      "type": "string",
      "enum": [
        "trend_pullback",
        "base_breakout",
        "avwap_reclaim"
      ]
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "symbol",
          "classification_status",
          "packet_id"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "pattern": "^cand_[a-z0-9_]+_[0-9a-f]{16}$"
          },
          "symbol": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9.-]{0,9}$"
          },
          "classification_status": {
            "type": "string",
            "enum": [
              "ok",
              "missing",
              "unsupported",
              "stale",
              "low_confidence"
            ]
          },
          "packet_id": {
            "type": "string",
            "pattern": "^pkt_[a-z0-9_]+_[0-9]{8}_[0-9a-f]{16}$"
          }
        }
      }
    }
  }
}
